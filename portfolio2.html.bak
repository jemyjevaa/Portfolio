<script>
/* DARK MODE */
const html = document.documentElement;
const btn = document.getElementById('themeToggle');
const saved = localStorage.getItem('pt') || 'light';
html.setAttribute('data-theme', saved);
btn.textContent = saved === 'dark' ? '☀️' : '🌙';
btn.addEventListener('click', () => {
  const n = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
  html.setAttribute('data-theme', n);
  btn.textContent = n === 'dark' ? '☀️' : '🌙';
  localStorage.setItem('pt', n);
});

/* SCROLL REVEAL */
const ro = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); ro.unobserve(e.target); } });
}, { threshold: 0.07, rootMargin: '0px 0px -30px 0px' });
document.querySelectorAll('.reveal').forEach(el => ro.observe(el));
['projects-grid','platform-row','skills-grid','testi-grid','blog-grid','compare-grid'].forEach(cls => {
  document.querySelectorAll('.' + cls).forEach(p => p.querySelectorAll('.reveal').forEach((c,i) => { c.style.transitionDelay = (i*70)+'ms'; }));
});

/* COUNT UP */
function cu(el) {
  const t = +el.dataset.t, d = 1400, s = performance.now();
  (function step(n) {
    const p = Math.min((n - s) / d, 1), e = 1 - Math.pow(1 - p, 3);
    el.textContent = Math.round(t * e);
    if (p < 1) requestAnimationFrame(step); else el.textContent = t;
  })(s);
}
const so = new IntersectionObserver(e => {
  if (e[0].isIntersecting) { document.querySelectorAll('.cu').forEach(cu); so.disconnect(); }
}, { threshold: 0.3 });
const se = document.getElementById('stats');
if (se) so.observe(se);

/* COMPARE TABS */
function switchTab(id, el) {
  document.querySelectorAll('.compare-body').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.ctab').forEach(t => t.classList.remove('active'));
  document.getElementById('tab-' + id).classList.add('active');
  (el || event.target).classList.add('active');
}

/* PLAYGROUND */
let codeTab = 'tw';
function isLight(hex) {
  const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);
  return (r*299+g*587+b*114)/1000>128;
}
function toFlutter(h) { return '0xFF'+h.slice(1).toUpperCase(); }
function lightenHex(hex, p) {
  let r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);
  return '#'+[Math.min(255,r+Math.round((255-r)*p)),Math.min(255,g+Math.round((255-g)*p)),Math.min(255,b+Math.round((255-b)*p))].map(x=>x.toString(16).padStart(2,'0')).join('');
}
function upd() {
  const pr=document.getElementById('cp').value, ac=document.getElementById('ca').value, su=document.getElementById('cs2').value;
  const rad=document.getElementById('rr').value, fsz=document.getElementById('rs').value, fnt=document.getElementById('sf').value;
  document.getElementById('rv').textContent = rad;
  document.getElementById('sv').textContent = fsz;
  document.getElementById('bg1').style.background = pr;
  document.getElementById('bg2').style.background = ac;
  document.getElementById('bg3').style.background = su;
  const onPr = isLight(pr)?'#111':'#fff', onAc = isLight(ac)?'#111':'#fff', onSu = isLight(su)?'#111':'#888';
  // web card
  const wc=document.getElementById('wcard');
  wc.style.background=su; wc.style.borderRadius=rad+'px';
  wc.style.borderColor=isLight(su)?'rgba(0,0,0,.08)':'rgba(255,255,255,.08)';
  const wh=document.getElementById('whead'); wh.style.fontFamily=fnt; wh.style.fontSize=(+fsz*1.3)+'px'; wh.style.color=onSu==='#111'?'#0e0e0e':'#f0ede8';
  document.getElementById('wbody').style.fontSize=fsz+'px';
  const wb=document.getElementById('wbtn'); wb.style.background=pr; wb.style.color=onPr; wb.style.borderRadius=rad+'px'; wb.style.fontFamily=fnt;
  const wbg=document.getElementById('wbadge'); wbg.style.background=ac; wbg.style.color=onAc; wbg.style.borderRadius=(+rad/2)+'px';
  // flutter
  const fc=document.getElementById('fcard'); fc.style.background=su; fc.style.borderRadius=rad+'px'; fc.style.borderColor=isLight(su)?'rgba(0,0,0,.06)':'rgba(255,255,255,.06)';
  const fh=document.getElementById('fhead'); fh.style.fontFamily=fnt; fh.style.color=onSu==='#111'?'#0e0e0e':'#f0ede8'; fh.style.fontSize=(+fsz*.9)+'px';
  const fb=document.getElementById('fbtn'); fb.style.background=pr; fb.style.color=onPr; fb.style.borderRadius=rad+'px'; fb.style.fontFamily=fnt;
  document.getElementById('ft1').style.background=lightenHex(pr,.82); document.getElementById('ft1').style.color=pr;
  document.getElementById('ft2').style.background=lightenHex(ac,.85); document.getElementById('ft2').style.color=ac;
  // swiftui
  const sc=document.getElementById('scard'); sc.style.background=su; sc.style.borderRadius=rad+'px';
  const sh=document.getElementById('shead'); sh.style.fontFamily=fnt; sh.style.color=onSu==='#111'?'#0e0e0e':'#f0ede8'; sh.style.fontSize=(+fsz*.9)+'px';
  const sb=document.getElementById('sbtn'); sb.style.background=ac; sb.style.color=onAc; sb.style.borderRadius=rad+'px'; sb.style.fontFamily=fnt;
  genCode(pr,ac,su,rad,fsz,fnt);
}
function genCode(pr,ac,su,rad,fsz,fnt) {
  const o=document.getElementById('cout');
  const fn=fnt.split(',')[0].replace(/'/g,'');
  if(codeTab==='tw') o.innerHTML=`<span style="color:#7c3aed">// tailwind.config.js</span>\ntheme: { extend: {\n  colors: {\n    primary: <span style="color:#059669">"${pr}"</span>,\n    accent: <span style="color:#059669">"${ac}"</span>,\n    surface: <span style="color:#059669">"${su}"</span>\n  },\n  borderRadius: { lg: <span style="color:#059669">"${rad}px"</span> },\n  fontSize: { base: <span style="color:#059669">"${fsz}px"</span> },\n  fontFamily: { display: <span style="color:#059669">["${fn}"]</span> }\n}}`;
  else if(codeTab==='fl') o.innerHTML=`<span style="color:#7c3aed">// app_tokens.dart</span>\nclass AppTokens {\n  static const colorPrimary =\n    Color(<span style="color:#059669">${toFlutter(pr)}</span>);\n  static const colorAccent =\n    Color(<span style="color:#059669">${toFlutter(ac)}</span>);\n  static const colorSurface =\n    Color(<span style="color:#059669">${toFlutter(su)}</span>);\n  static const radiusLg = <span style="color:#059669">${rad}.0</span>;\n  static const fontDisplay = <span style="color:#059669">'${fn}'</span>;\n}`;
  else o.innerHTML=`<span style="color:#7c3aed">// AppTokens.swift</span>\nenum AppTokens {\n  static let colorPrimary =\n    Color(hex: <span style="color:#059669">"${pr}"</span>)\n  static let colorAccent =\n    Color(hex: <span style="color:#059669">"${ac}"</span>)\n  static let colorSurface =\n    Color(hex: <span style="color:#059669">"${su}"</span>)\n  static let radiusLg: CGFloat = <span style="color:#059669">${rad}</span>\n  static let fontDisplay = <span style="color:#059669">"${fn}"</span>\n}`;
}
function swCode(tab, el) {
  codeTab = tab;
  document.querySelectorAll('.code-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  upd();
}
upd();
</script>
</body>
</html>
