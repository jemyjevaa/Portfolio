<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Portfolio — Dev & Design</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@300;400;500&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --ink: #0e0e0e; --ink-muted: #6b6b6b; --ink-faint: #c2c2c2;
  --surface: #f5f3ef; --surface-alt: #eceae4;
  --white: #ffffff; --card-bg: #ffffff; --nav-bg: rgba(245,243,239,0.92);
  --accent: #1a1a2e; --accent2: #c8572a; --accent3: #2d6a4f; --accent4: #5b4fcf;
  --tag-web: #e8f0fe; --tag-web-ink: #1a56db;
  --tag-mobile: #fef3e2; --tag-mobile-ink: #b45309;
  --tag-ios: #fce8e8; --tag-ios-ink: #991b1b;
  --tag-flutter: #e8f5fe; --tag-flutter-ink: #0369a1;
  --serif: 'DM Serif Display', serif; --sans: 'Syne', sans-serif; --mono: 'DM Mono', monospace;
  --radius: 3px; --radius-lg: 8px;
  --ease: cubic-bezier(0.16, 1, 0.3, 1);
  --shadow: 0 8px 32px rgba(0,0,0,0.07); --shadow-lg: 0 20px 60px rgba(0,0,0,0.10);
}
[data-theme="dark"] {
  --ink: #f0ede8; --ink-muted: #9a9590; --ink-faint: #3a3832;
  --surface: #111109; --surface-alt: #1c1b17;
  --white: #1c1b17; --card-bg: #1f1e1a; --nav-bg: rgba(17,17,9,0.92);
  --tag-web: #1a2540; --tag-web-ink: #7eb3f5;
  --tag-mobile: #2a1f0a; --tag-mobile-ink: #f9a825;
  --tag-ios: #2a0f0f; --tag-ios-ink: #f87171;
  --tag-flutter: #0a1f2a; --tag-flutter-ink: #38bdf8;
  --shadow: 0 8px 32px rgba(0,0,0,0.3); --shadow-lg: 0 20px 60px rgba(0,0,0,0.4);
}
html { scroll-behavior: smooth; }
body { background: var(--surface); color: var(--ink); font-family: var(--sans); font-size: 16px; line-height: 1.6; overflow-x: hidden; transition: background 0.3s, color 0.3s; }

/* NAV */
nav { position: fixed; top: 0; left: 0; right: 0; z-index: 200; display: flex; align-items: center; justify-content: space-between; padding: 0 3rem; height: 64px; background: var(--nav-bg); backdrop-filter: blur(14px); border-bottom: 1px solid var(--ink-faint); transition: background 0.3s, border-color 0.3s; }
.nav-logo { font-family: var(--mono); font-size: 13px; letter-spacing: 0.08em; color: var(--ink); text-decoration: none; }
.nav-links { display: flex; gap: 2rem; list-style: none; }
.nav-links a { font-size: 13px; font-weight: 500; letter-spacing: 0.06em; color: var(--ink-muted); text-decoration: none; text-transform: uppercase; transition: color 0.2s; }
.nav-links a:hover { color: var(--ink); }
.nav-right { display: flex; align-items: center; gap: 1rem; }
.theme-toggle { width: 40px; height: 40px; border-radius: 50%; background: var(--surface-alt); border: 1px solid var(--ink-faint); cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 16px; transition: all 0.2s; color: var(--ink); }
.theme-toggle:hover { border-color: var(--ink); }
.nav-cta { font-size: 13px; font-weight: 600; letter-spacing: 0.05em; padding: 0.5rem 1.2rem; background: var(--ink); color: var(--surface); border-radius: var(--radius); text-decoration: none; transition: all 0.2s; }
.nav-cta:hover { opacity: 0.8; transform: translateY(-1px); }

/* HERO */
#hero { min-height: 100vh; display: flex; align-items: center; padding: 8rem 3rem 4rem; overflow: hidden; }
.hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; max-width: 1200px; margin: 0 auto; width: 100%; align-items: center; }
.hero-tag { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--mono); font-size: 12px; letter-spacing: 0.1em; color: var(--accent2); background: rgba(200,87,42,0.08); padding: 0.35rem 0.9rem; border-radius: 99px; border: 1px solid rgba(200,87,42,0.2); margin-bottom: 1.5rem; animation: fadeUp 0.8s var(--ease) both; }
.hero-tag::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--accent2); animation: pulse 2s infinite; }
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(0.8)} }
.hero-name { font-family: var(--serif); font-size: clamp(3rem, 5vw, 5.5rem); line-height: 1.05; letter-spacing: -0.02em; color: var(--ink); animation: fadeUp 0.9s var(--ease) 0.1s both; }
.hero-name em { font-style: italic; color: var(--accent2); }
.hero-subtitle { margin-top: 1.5rem; font-size: 1.05rem; color: var(--ink-muted); max-width: 440px; line-height: 1.7; animation: fadeUp 1s var(--ease) 0.2s both; }
.hero-stack { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 2rem; animation: fadeUp 1s var(--ease) 0.3s both; }
.stack-badge { font-family: var(--mono); font-size: 11.5px; padding: 0.3rem 0.75rem; border-radius: 99px; border: 1px solid var(--ink-faint); color: var(--ink-muted); background: var(--card-bg); letter-spacing: 0.04em; transition: all 0.2s; }
.stack-badge:hover { border-color: var(--ink); color: var(--ink); transform: translateY(-1px); }
.hero-actions { display: flex; gap: 1rem; margin-top: 2.5rem; animation: fadeUp 1s var(--ease) 0.4s both; }
.btn-primary { font-size: 14px; font-weight: 600; padding: 0.75rem 1.8rem; background: var(--ink); color: var(--surface); border-radius: var(--radius); text-decoration: none; transition: all 0.2s; letter-spacing: 0.02em; }
.btn-primary:hover { opacity: 0.8; transform: translateY(-2px); }
.btn-secondary { font-size: 14px; font-weight: 500; padding: 0.75rem 1.8rem; border: 1px solid var(--ink); color: var(--ink); border-radius: var(--radius); text-decoration: none; transition: all 0.2s; }
.btn-secondary:hover { background: var(--ink); color: var(--surface); }
.hero-visual { display: flex; flex-direction: column; gap: 1rem; animation: fadeIn 1.2s var(--ease) 0.3s both; position: relative; }
.device-frame { border-radius: 16px; overflow: hidden; border: 1.5px solid var(--ink-faint); background: var(--card-bg); box-shadow: var(--shadow-lg); }
.device-bar { height: 40px; background: var(--surface-alt); border-bottom: 1px solid var(--ink-faint); display: flex; align-items: center; gap: 0.5rem; padding: 0 1rem; }
.dot { width: 10px; height: 10px; border-radius: 50%; }
.dot-r{background:#ff5f56}.dot-y{background:#ffbd2e}.dot-g{background:#27c93f}
.device-content { padding: 1.5rem; min-height: 180px; }
.code-line { font-family: var(--mono); font-size: 12.5px; line-height: 2; color: var(--ink-muted); }
.kw{color:#7c3aed}.fn{color:var(--accent2)}.str{color:#059669}.cm{color:var(--ink-faint);font-style:italic}.type{color:#0369a1}
.mobile-row { display: flex; gap: 1rem; }
.mobile-frame { flex: 1; border-radius: 20px; border: 1.5px solid var(--ink-faint); background: var(--card-bg); overflow: hidden; box-shadow: var(--shadow); }
.mobile-notch { height: 28px; background: var(--ink); display: flex; align-items: center; justify-content: center; }
.notch-pill { width: 60px; height: 10px; background: #333; border-radius: 99px; }
.mobile-content { padding: 1rem; }
.mobile-card { background: linear-gradient(135deg, #1a1a2e, #2d2d5e); border-radius: 10px; padding: 1rem; color: white; font-size: 11px; font-family: var(--mono); line-height: 1.8; }
.mc-label{opacity:.5;font-size:9px;text-transform:uppercase;letter-spacing:.1em}
.mc-value{font-size:18px;font-weight:500;margin:.2rem 0}
.mui-row{display:flex;gap:.4rem;margin-top:.4rem}
.mui-btn{flex:1;height:28px;border-radius:6px;background:var(--surface-alt)}
.mui-btn-main{background:var(--ink)}
.floating-badge { position:absolute; background:var(--card-bg); border:1px solid var(--ink-faint); border-radius:var(--radius-lg); padding:.6rem 1rem; font-size:12px; font-weight:600; box-shadow:var(--shadow); display:flex; align-items:center; gap:.5rem; white-space:nowrap; color:var(--ink); }
.fb-1{top:-1rem;right:-1rem}.fb-2{bottom:2rem;left:-1.5rem}
.fb-dot{width:8px;height:8px;border-radius:50%}

/* SECTION */
section { padding: 6rem 3rem; }
.section-inner { max-width: 1200px; margin: 0 auto; }
.section-label { font-family: var(--mono); font-size: 11px; letter-spacing: .15em; text-transform: uppercase; color: var(--accent2); margin-bottom: .5rem; }
.section-title { font-family: var(--serif); font-size: clamp(2rem, 3.5vw, 3.2rem); line-height: 1.1; color: var(--ink); margin-bottom: 1rem; }
.section-lead { font-size: 1.05rem; color: var(--ink-muted); max-width: 560px; line-height: 1.75; margin-bottom: 3rem; }
.divider { width: 40px; height: 2px; background: var(--accent2); margin: 1rem 0 2rem; }

/* STATS */
#stats { background: var(--ink); padding: 2.5rem 3rem; }
.stats-row { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); }
.stat-item { text-align: center; padding: 1rem; border-right: 1px solid rgba(255,255,255,0.08); }
.stat-item:last-child { border-right: none; }
.stat-val { font-family: var(--serif); font-size: 2.8rem; color: var(--accent2); line-height: 1; }
.stat-label { font-size: 12px; color: rgba(245,243,239,0.45); margin-top: .4rem; font-family: var(--mono); letter-spacing: .08em; }
.stat-sub { font-size: 11px; color: rgba(245,243,239,0.2); margin-top: .2rem; }

/* ABOUT */
#about { background: var(--card-bg); }
.about-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 5rem; align-items: start; }
.about-photo { aspect-ratio: 3/4; background: var(--surface-alt); border-radius: var(--radius-lg); overflow: hidden; position: relative; }
.photo-placeholder { width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-family:var(--serif);font-size:5rem;color:var(--ink-faint);background:var(--surface-alt); }
.photo-label { position:absolute;bottom:1.5rem;left:1.5rem;background:var(--card-bg);padding:.5rem 1rem;border-radius:var(--radius);font-size:12px;font-weight:600;letter-spacing:.05em;color:var(--ink); }
.about-text h3 { font-family:var(--serif);font-size:1.6rem;margin-bottom:1rem;line-height:1.3;color:var(--ink); }
.about-text p { color:var(--ink-muted);line-height:1.8;margin-bottom:1.2rem; }
.skills-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-top:2rem; }
.skill-group { padding:1.2rem;background:var(--surface);border-radius:var(--radius-lg);border:1px solid var(--surface-alt); }
.skill-group-label { font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-muted);margin-bottom:.75rem; }
.skill-item { display:flex;align-items:center;gap:.5rem;font-size:13px;font-family:var(--mono);color:var(--ink);padding:.25rem 0; }
.skill-dot{width:5px;height:5px;border-radius:50%;background:var(--accent2);flex-shrink:0}

/* PROJECTS */
#projects { background: var(--surface); }
.projects-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem; }
.project-card { background:var(--card-bg);border-radius:var(--radius-lg);overflow:hidden;border:1px solid var(--ink-faint);transition:transform .3s var(--ease),box-shadow .3s var(--ease);cursor:pointer; }
.project-card:hover { transform:translateY(-4px);box-shadow:var(--shadow-lg); }
.project-card.featured { grid-column:span 2; }
.project-thumb { height:200px;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center; }
.project-card.featured .project-thumb { height:260px; }
.project-body { padding:1.5rem; }
.project-platform-tags { display:flex;gap:.4rem;flex-wrap:wrap;margin-bottom:.75rem; }
.ptag { font-size:11px;font-weight:600;padding:.2rem .6rem;border-radius:99px;letter-spacing:.03em; }
.ptag-web{background:var(--tag-web);color:var(--tag-web-ink)}
.ptag-mobile{background:var(--tag-mobile);color:var(--tag-mobile-ink)}
.ptag-ios{background:var(--tag-ios);color:var(--tag-ios-ink)}
.ptag-flutter{background:var(--tag-flutter);color:var(--tag-flutter-ink)}
.project-title{font-family:var(--serif);font-size:1.3rem;margin-bottom:.5rem;color:var(--ink)}
.project-desc{font-size:14px;color:var(--ink-muted);line-height:1.7;margin-bottom:1rem}
.project-metrics { display:flex;gap:1.25rem;margin-bottom:1rem;padding:.75rem;background:var(--surface);border-radius:var(--radius);flex-wrap:wrap; }
.pm-item { display:flex;flex-direction:column; }
.pm-val { font-family:var(--mono);font-size:15px;font-weight:500;color:var(--ink); }
.pm-label { font-size:10px;color:var(--ink-muted);text-transform:uppercase;letter-spacing:.08em; }
.project-footer { display:flex;align-items:center;justify-content:space-between;padding-top:1rem;border-top:1px solid var(--surface-alt); }
.project-tech{font-family:var(--mono);font-size:11px;color:var(--ink-faint)}
.project-link{font-size:13px;font-weight:600;color:var(--ink);text-decoration:none;display:flex;align-items:center;gap:.3rem;letter-spacing:.03em;transition:color .2s}
.project-link:hover{color:var(--accent2)}
.project-link svg{width:14px;height:14px}

/* COMPARE */
#platform-compare { background: var(--card-bg); }
.compare-tabs { display:flex;margin-bottom:2.5rem;border:1px solid var(--ink-faint);border-radius:var(--radius-lg);overflow:hidden;width:fit-content; }
.ctab { font-size:13px;font-weight:600;padding:.65rem 1.5rem;cursor:pointer;color:var(--ink-muted);background:transparent;border:none;font-family:var(--sans);letter-spacing:.04em;transition:all .2s; }
.ctab.active { background:var(--ink);color:var(--surface); }
.ctab:hover:not(.active){color:var(--ink)}
.compare-body { display:none; }
.compare-body.active { display:block; }
.compare-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem; }
.comp-col { border:1px solid var(--ink-faint);border-radius:var(--radius-lg);overflow:hidden; }
.comp-header { padding:1rem 1.25rem;border-bottom:1px solid var(--ink-faint);display:flex;align-items:center;gap:.75rem;background:var(--card-bg); }
.comp-icon { width:32px;height:32px;border-radius:var(--radius);display:flex;align-items:center;justify-content:center;font-size:16px; }
.comp-title{font-weight:700;font-size:14px;color:var(--ink)}
.comp-sub{font-size:11px;color:var(--ink-muted)}
.comp-code { background:var(--surface);padding:1.25rem;font-family:var(--mono);font-size:11.5px;line-height:1.85;color:var(--ink-muted);min-height:220px; }
.comp-code .ck{color:#7c3aed}.comp-code .cf{color:var(--accent2)}.comp-code .cs{color:#059669}.comp-code .cp{color:#0369a1}.comp-code .cc{color:var(--ink-faint);font-style:italic}

/* CROSSPLATFORM */
#crossplatform { background: var(--ink); color: var(--surface); padding: 5rem 3rem; }
#crossplatform .section-label{color:var(--accent2)}
#crossplatform .section-title{color:var(--surface)}
#crossplatform .section-lead{color:rgba(245,243,239,.6)}
.platform-row { display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;margin-top:3rem; }
.platform-card { border:1px solid rgba(255,255,255,.1);border-radius:var(--radius-lg);padding:1.5rem;transition:all .2s; }
.platform-card:hover{border-color:rgba(255,255,255,.3);background:rgba(255,255,255,.04)}
.platform-icon{width:44px;height:44px;border-radius:var(--radius);display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:1rem}
.platform-name{font-size:15px;font-weight:700;letter-spacing:.02em;margin-bottom:.4rem;color:var(--surface)}
.platform-desc{font-size:13px;color:rgba(245,243,239,.5);line-height:1.65}
.platform-chips{display:flex;flex-wrap:wrap;gap:.4rem;margin-top:.9rem}
.pchip{font-family:var(--mono);font-size:10px;padding:.2rem .55rem;background:rgba(255,255,255,.07);border-radius:99px;color:rgba(245,243,239,.5);letter-spacing:.04em}

/* PLAYGROUND */
#playground { background: var(--surface); }
.playground-wrap { display:grid;grid-template-columns:300px 1fr;gap:2rem;align-items:start;margin-top:2rem; }
.playground-controls { background:var(--card-bg);border:1px solid var(--ink-faint);border-radius:var(--radius-lg);padding:1.5rem;position:sticky;top:80px; }
.ctrl-section { margin-bottom:1.5rem; }
.ctrl-section:last-child{margin-bottom:0}
.ctrl-label{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-muted);margin-bottom:.75rem;display:block}
.ctrl-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:.6rem}
.ctrl-name{font-size:12px;font-family:var(--mono);color:var(--ink-muted)}
.ctrl-swatch{width:28px;height:28px;border-radius:4px;border:1px solid var(--ink-faint);cursor:pointer;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
.ctrl-swatch input{position:absolute;inset:0;opacity:0;cursor:pointer;width:300%;height:300%;transform:translate(-33%,-33%)}
.ctrl-bg{width:100%;height:100%}
.range-row{margin-bottom:.65rem}
.range-row label{display:flex;justify-content:space-between;font-size:12px;color:var(--ink-muted);font-family:var(--mono);margin-bottom:.3rem}
.range-row input[type=range]{width:100%;accent-color:var(--accent2)}
.sel-row{margin-bottom:.65rem}
.sel-row label{display:block;font-size:12px;color:var(--ink-muted);font-family:var(--mono);margin-bottom:.3rem}
.sel-row select{width:100%;padding:.4rem .6rem;background:var(--surface);border:1px solid var(--ink-faint);border-radius:var(--radius);font-family:var(--mono);font-size:12px;color:var(--ink);outline:none}
.code-tab-row{display:flex;border-bottom:1px solid var(--ink-faint);margin-bottom:0}
.code-tab{font-size:11px;font-family:var(--mono);padding:.35rem .8rem;cursor:pointer;color:var(--ink-muted);background:transparent;border:none;border-bottom:2px solid transparent;transition:all .15s}
.code-tab.active{color:var(--ink);border-bottom-color:var(--accent2)}
.code-out{background:var(--surface);padding:.9rem 1rem;font-family:var(--mono);font-size:11px;line-height:1.8;color:var(--ink-muted);max-height:150px;overflow-y:auto;border-radius:0 0 var(--radius-lg) var(--radius-lg)}
.playground-preview { display:flex;flex-direction:column;gap:1.5rem; }
.preview-label { font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-muted);margin-bottom:.75rem;display:flex;align-items:center;gap:.5rem; }
.preview-label::after{content:'';flex:1;height:1px;background:var(--ink-faint)}
.preview-panel{background:var(--card-bg);border:1px solid var(--ink-faint);border-radius:var(--radius-lg);overflow:hidden}
.pv-topbar{height:32px;background:var(--surface-alt);display:flex;align-items:center;gap:.4rem;padding:0 .75rem;border-bottom:1px solid var(--ink-faint)}
.pv-dot{width:8px;height:8px;border-radius:50%}
.pv-body{padding:1.25rem}
.mpv-wrap{display:flex;gap:1rem}
.mpv-frame{flex:1;border:1.5px solid var(--ink-faint);border-radius:14px;overflow:hidden}
.mpv-notch{height:20px;background:#111;display:flex;align-items:center;justify-content:center}
.mpv-pill{width:40px;height:5px;border-radius:99px;background:#222}
.mpv-body{padding:.75rem}

/* PROCESS */
#process { background: var(--card-bg); }
.process-timeline{display:grid;grid-template-columns:repeat(5,1fr);gap:0;margin-top:3rem;position:relative}
.process-timeline::before{content:'';position:absolute;top:28px;left:10%;right:10%;height:1px;background:var(--ink-faint);z-index:0}
.process-step{text-align:center;padding:0 .5rem;position:relative;z-index:1}
.step-num{width:56px;height:56px;border-radius:50%;background:var(--surface);border:2px solid var(--ink-faint);display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:13px;font-weight:500;margin:0 auto 1rem;transition:all .2s;color:var(--ink)}
.process-step:hover .step-num{background:var(--ink);color:var(--surface);border-color:var(--ink)}
.step-title{font-weight:700;font-size:13px;letter-spacing:.04em;margin-bottom:.4rem;color:var(--ink)}
.step-desc{font-size:12px;color:var(--ink-muted);line-height:1.6}

/* CASE STUDY */
#casestudy{background:var(--surface)}
.case-grid{display:grid;grid-template-columns:1.2fr 1fr;gap:4rem;align-items:start}
.case-screen{background:var(--card-bg);border-radius:24px;border:1.5px solid var(--ink-faint);overflow:hidden;box-shadow:var(--shadow-lg)}
.cs-topbar{background:var(--ink);padding:1rem 1.5rem;display:flex;align-items:center;justify-content:space-between}
.cs-logo{font-family:var(--mono);font-size:13px;color:var(--surface)}
.cs-dots{display:flex;gap:.4rem}
.cs-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.25)}
.cs-body{padding:1.5rem}
.cs-hero-card{background:linear-gradient(135deg,#1a1a2e 0%,#2d6a4f 100%);border-radius:12px;padding:1.5rem;color:white;margin-bottom:1rem}
.cs-kpi-row{display:flex;gap:.75rem;margin-bottom:1rem}
.cs-kpi{flex:1;background:var(--surface);border-radius:8px;padding:.75rem;text-align:center}
.cs-kpi-val{font-size:18px;font-weight:700;color:var(--ink)}
.cs-kpi-label{font-size:10px;color:var(--ink-muted);margin-top:2px}
.cs-list{list-style:none}
.cs-list li{display:flex;align-items:center;gap:.6rem;padding:.6rem 0;border-bottom:1px solid var(--surface-alt)}
.cs-list li:last-child{border-bottom:none}
.cs-avatar{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600}
.cs-info{flex:1}
.cs-name{font-size:12px;font-weight:600;color:var(--ink)}
.cs-sub{font-size:10px;color:var(--ink-muted)}
.cs-amount{font-family:var(--mono);font-size:12px;font-weight:500}
.case-details{display:flex;flex-direction:column;gap:2rem}
.challenge-block,.solution-block{padding:1.5rem;border-radius:var(--radius-lg);border:1px solid var(--surface-alt);background:var(--card-bg)}
.cb-label{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;margin-bottom:.75rem}
.cb-challenge{color:var(--accent2)}.cb-solution{color:var(--accent3)}
.cb-text{font-size:14px;color:var(--ink-muted);line-height:1.8}
.result-chips{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:1rem}
.result-chip{font-size:12px;font-weight:600;padding:.35rem .85rem;border-radius:99px;background:rgba(45,106,79,.1);color:var(--accent3)}

/* TESTIMONIALS */
#testimonials { background: var(--card-bg); }
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
.testi-card{background:var(--surface);border-radius:var(--radius-lg);padding:1.75rem;border:1px solid var(--ink-faint);transition:all .2s;position:relative}
.testi-card:hover{border-color:var(--ink-muted);transform:translateY(-2px);box-shadow:var(--shadow)}
.testi-card.feat{background:var(--ink);border-color:var(--ink)}
.testi-metric{position:absolute;top:1.25rem;right:1.25rem;font-family:var(--mono);font-size:11px;font-weight:600;padding:.25rem .6rem;border-radius:99px;background:rgba(200,87,42,.1);color:var(--accent2)}
.testi-card.feat .testi-metric{background:rgba(200,87,42,.25);color:#f0a882}
.testi-mark{font-size:2.5rem;font-family:var(--serif);line-height:1;color:var(--accent2);margin-bottom:.5rem}
.testi-quote{font-family:var(--serif);font-size:1rem;line-height:1.75;color:var(--ink);margin-bottom:1.25rem}
.testi-card.feat .testi-quote{color:var(--surface)}
.testi-author{display:flex;align-items:center;gap:.75rem;padding-top:1rem;border-top:1px solid var(--ink-faint)}
.testi-card.feat .testi-author{border-top-color:rgba(255,255,255,.12)}
.testi-avatar{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;flex-shrink:0}
.testi-name{font-size:13px;font-weight:700;color:var(--ink)}
.testi-card.feat .testi-name{color:var(--surface)}
.testi-role{font-size:11px;color:var(--ink-muted);font-family:var(--mono)}
.testi-card.feat .testi-role{color:rgba(245,243,239,.5)}

/* BLOG */
#blog{background:var(--surface)}
.blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
.blog-card{background:var(--card-bg);border-radius:var(--radius-lg);border:1px solid var(--ink-faint);overflow:hidden;transition:all .2s;cursor:pointer;text-decoration:none;display:block;color:inherit}
.blog-card:hover{transform:translateY(-3px);box-shadow:var(--shadow)}
.blog-thumb{height:140px;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
.blog-cat{position:absolute;top:.75rem;left:.75rem;font-family:var(--mono);font-size:10px;font-weight:600;letter-spacing:.08em;padding:.25rem .6rem;border-radius:99px}
.blog-body{padding:1.25rem}
.blog-title{font-family:var(--serif);font-size:1.05rem;line-height:1.3;color:var(--ink);margin-bottom:.5rem}
.blog-excerpt{font-size:13px;color:var(--ink-muted);line-height:1.7;margin-bottom:1rem}
.blog-meta{display:flex;align-items:center;justify-content:space-between}
.blog-date{font-family:var(--mono);font-size:11px;color:var(--ink-faint)}
.blog-tag{font-family:var(--mono);font-size:10px;padding:.2rem .55rem;border-radius:99px;border:1px solid var(--ink-faint);color:var(--ink-muted)}
.blog-readtime{font-size:12px;color:var(--ink-muted)}

/* CONTACT */
#contact{background:var(--ink);color:var(--surface)}
#contact .section-label{color:var(--accent2)}
#contact .section-title{color:var(--surface)}
.contact-centered{max-width:680px;margin:0 auto;text-align:center}
.contact-copy{font-size:1.05rem;color:rgba(245,243,239,.6);line-height:1.8;margin-bottom:2.5rem}
.contact-cta{display:inline-flex;align-items:center;gap:.75rem;font-size:1.05rem;font-weight:700;padding:1rem 2.5rem;background:var(--accent2);color:white;border-radius:var(--radius-lg);text-decoration:none;transition:all .2s;letter-spacing:.02em;margin-bottom:3rem}
.contact-cta:hover{background:#b04a21;transform:translateY(-3px);box-shadow:0 12px 32px rgba(200,87,42,.35)}
.contact-or{font-family:var(--mono);font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:rgba(245,243,239,.2);margin-bottom:1.75rem}
.contact-links{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
.cl-link{display:flex;align-items:center;gap:.6rem;font-size:13px;font-weight:500;color:rgba(245,243,239,.65);text-decoration:none;padding:.65rem 1.25rem;border:1px solid rgba(255,255,255,.1);border-radius:var(--radius-lg);transition:all .2s}
.cl-link:hover{background:rgba(255,255,255,.05);border-color:rgba(255,255,255,.25);color:var(--surface);transform:translateY(-2px)}
.avail{display:inline-flex;align-items:center;gap:.5rem;font-family:var(--mono);font-size:12px;color:rgba(245,243,239,.3);margin-top:2.5rem;padding:.5rem 1rem;border:1px solid rgba(255,255,255,.07);border-radius:99px}
.avail-dot{width:6px;height:6px;border-radius:50%;background:#4ade80;animation:pulse 2s infinite}

footer{background:#050505;color:rgba(245,243,239,.2);padding:2rem 3rem;display:flex;align-items:center;justify-content:space-between;font-size:12px;font-family:var(--mono);border-top:1px solid rgba(255,255,255,.05)}

/* REVEAL & ANIMS */
.reveal{opacity:0;transform:translateY(24px);transition:opacity .7s var(--ease),transform .7s var(--ease)}
.reveal.visible{opacity:1;transform:none}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:none}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
.float{animation:float 4s ease-in-out infinite}

/* RESPONSIVE */
@media(max-width:900px){
  nav{padding:0 1.5rem}
  nav .nav-links{display:none}
  #hero{padding:7rem 1.5rem 4rem}
  .hero-grid{grid-template-columns:1fr}
  .hero-visual{display:none}
  section{padding:4rem 1.5rem}
  #stats{padding:2rem 1.5rem}
  .stats-row{grid-template-columns:1fr 1fr}
  .about-grid,.case-grid{grid-template-columns:1fr}
  .projects-grid{grid-template-columns:1fr}
  .project-card.featured{grid-column:span 1}
  .platform-row{grid-template-columns:1fr 1fr}
  .process-timeline{grid-template-columns:1fr 1fr}
  .process-timeline::before{display:none}
  .skills-grid{grid-template-columns:1fr 1fr}
  .testi-grid,.blog-grid,.compare-grid{grid-template-columns:1fr}
  .playground-wrap{grid-template-columns:1fr}
  .mpv-wrap{flex-direction:column}
  .contact-links{flex-direction:column;align-items:center}
}
</style>
</head>
<body>

<nav>
  <a href="#" class="nav-logo">∙ DEV.PORTFOLIO</a>
  <ul class="nav-links">
    <li><a href="#about">Sobre mí</a></li>
    <li><a href="#projects">Proyectos</a></li>
    <li><a href="#platform-compare">Stack</a></li>
    <li><a href="#playground">Tokens</a></li>
    <li><a href="#blog">Blog</a></li>
    <li><a href="#contact">Contacto</a></li>
  </ul>
  <div class="nav-right">
    <button class="theme-toggle" id="themeToggle" title="Cambiar tema">🌙</button>
    <a href="#contact" class="nav-cta">Hablemos →</a>
  </div>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="hero-grid">
    <div>
      <div class="hero-tag">Disponible para proyectos · 2026</div>
      <h1 class="hero-name">Diseño que<br><em>vive</em> en cada<br>plataforma.</h1>
      <p class="hero-subtitle">Desarrolladora full-stack especializada en experiencias coherentes a través de React, Flutter y Swift. Del pixel al bundle, en tres ecosistemas a la vez.</p>
      <div class="hero-stack">
        <span class="stack-badge">React</span><span class="stack-badge">Tailwind CSS</span><span class="stack-badge">Flutter</span><span class="stack-badge">Dart</span><span class="stack-badge">Swift</span><span class="stack-badge">SwiftUI</span><span class="stack-badge">Node.js</span><span class="stack-badge">TypeScript</span>
      </div>
      <div class="hero-actions">
        <a href="#projects" class="btn-primary">Ver proyectos</a>
        <a href="#contact" class="btn-secondary">Contactar</a>
      </div>
    </div>
    <div class="hero-visual float">
      <div class="device-frame">
        <div class="device-bar"><div class="dot dot-r"></div><div class="dot dot-y"></div><div class="dot dot-g"></div></div>
        <div class="device-content">
          <div class="code-line"><span class="cm">// design-tokens.ts — fuente única de verdad</span></div>
          <div class="code-line"><span class="kw">export const</span> <span class="fn">tokens</span> = {</div>
          <div class="code-line">&nbsp;&nbsp;color: { primary: <span class="str">"#1a1a2e"</span>, accent: <span class="str">"#c8572a"</span> },</div>
          <div class="code-line">&nbsp;&nbsp;radius: { sm: <span class="str">"4px"</span>, lg: <span class="str">"12px"</span> },</div>
          <div class="code-line">&nbsp;&nbsp;font: { display: <span class="str">"'Syne'"</span>, mono: <span class="str">"'DM Mono'"</span> }</div>
          <div class="code-line">}; <span class="cm">// → Tailwind · Flutter · SwiftUI</span></div>
        </div>
      </div>
      <div class="mobile-row">
        <div class="mobile-frame">
          <div class="mobile-notch"><div class="notch-pill"></div></div>
          <div class="mobile-content">
            <div class="mobile-card"><div class="mc-label">Balance</div><div class="mc-value">$4,820.00</div><div style="font-size:9px;opacity:.4">↑ 12.4%</div></div>
            <div class="mui-row"><div class="mui-btn" style="height:20px"></div><div class="mui-btn" style="height:20px;flex:2"></div></div>
            <div class="mui-row"><div class="mui-btn mui-btn-main" style="height:26px"></div><div class="mui-btn" style="height:26px"></div></div>
          </div>
        </div>
        <div class="mobile-frame">
          <div class="mobile-notch"><div class="notch-pill"></div></div>
          <div class="mobile-content">
            <div style="background:#f0faf6;border-radius:8px;padding:.75rem;margin-bottom:.5rem"><div style="font-size:9px;color:#059669;font-weight:700;text-transform:uppercase;letter-spacing:.08em">Flutter · iOS</div><div style="font-size:13px;font-weight:700;color:#1a1a2e;margin-top:2px">FitTrack Pro</div></div>
            <div class="mui-row"><div class="mui-btn" style="height:18px;flex:1"></div><div class="mui-btn" style="height:18px;flex:1;background:#e8f0fe"></div></div>
            <div class="mui-row"><div class="mui-btn" style="height:40px;flex:1;background:#1a1a2e;border-radius:8px"></div></div>
          </div>
        </div>
      </div>
      <div class="floating-badge fb-1" style="animation:float 3s 1s ease-in-out infinite"><div class="fb-dot" style="background:#27c93f"></div>Cross-platform ✓</div>
      <div class="floating-badge fb-2" style="animation:float 3.5s .5s ease-in-out infinite"><div class="fb-dot" style="background:var(--accent4)"></div>1 Design System</div>
    </div>
  </div>
</section>

<!-- STATS -->
<div id="stats">
  <div class="stats-row">
    <div class="stat-item"><div class="stat-val"><span class="cu" data-t="24">0</span>+</div><div class="stat-label">Proyectos entregados</div><div class="stat-sub">web · mobile · cross-platform</div></div>
    <div class="stat-item"><div class="stat-val"><span class="cu" data-t="138">0</span>k</div><div class="stat-label">Descargas acumuladas</div><div class="stat-sub">App Store + Google Play</div></div>
    <div class="stat-item"><div class="stat-val">4.<span class="cu" data-t="9">0</span>★</div><div class="stat-label">Rating promedio</div><div class="stat-sub">en stores de aplicaciones</div></div>
    <div class="stat-item"><div class="stat-val"><span class="cu" data-t="60">0</span>%</div><div class="stat-label">Reducción QA visual</div><div class="stat-sub">con design systems unificados</div></div>
  </div>
</div>

<!-- ABOUT -->
<section id="about">
  <div class="section-inner">
    <div class="about-grid">
      <div>
        <div class="about-photo"><div class="photo-placeholder">✦</div><div class="photo-label">Desarrolladora · Diseñadora</div></div>
      </div>
      <div class="reveal">
        <div class="section-label">// Sobre mí</div>
        <div class="divider"></div>
        <h3 style="font-family:var(--serif);font-size:1.6rem;margin-bottom:1rem;line-height:1.3;color:var(--ink)">Construyo software que se siente bien en cualquier pantalla.</h3>
        <p style="color:var(--ink-muted);line-height:1.8;margin-bottom:1.2rem">Soy desarrolladora especializada en interfaces cross-platform con foco en coherencia visual y rendimiento. Conecto el diseño de sistemas con implementación técnica robusta.</p>
        <p style="color:var(--ink-muted);line-height:1.8;margin-bottom:1.2rem">Trabajo con equipos de producto para traducir ideas en experiencias que funcionan igual en un iPhone que en un dashboard empresarial, con el design system como hilo conductor.</p>
        <div class="skills-grid">
          <div class="skill-group"><div class="skill-group-label">Web</div><div class="skill-item"><div class="skill-dot"></div>React 18+</div><div class="skill-item"><div class="skill-dot"></div>Tailwind CSS</div><div class="skill-item"><div class="skill-dot"></div>TypeScript</div><div class="skill-item"><div class="skill-dot"></div>Next.js</div></div>
          <div class="skill-group"><div class="skill-group-label">Mobile</div><div class="skill-item"><div class="skill-dot"></div>Flutter</div><div class="skill-item"><div class="skill-dot"></div>Dart</div><div class="skill-item"><div class="skill-dot"></div>Swift</div><div class="skill-item"><div class="skill-dot"></div>SwiftUI</div></div>
          <div class="skill-group"><div class="skill-group-label">Tools</div><div class="skill-item"><div class="skill-dot"></div>Node.js</div><div class="skill-item"><div class="skill-dot"></div>Firebase</div><div class="skill-item"><div class="skill-dot"></div>Git/GitHub</div><div class="skill-item"><div class="skill-dot"></div>Figma</div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PROJECTS -->
<section id="projects">
  <div class="section-inner">
    <div class="section-label reveal">// Proyectos</div>
    <h2 class="section-title reveal">Trabajo seleccionado</h2>
    <p class="section-lead reveal">Proyectos con métricas reales donde la coherencia cross-platform fue el requisito central.</p>
    <div class="projects-grid">
      <!-- 1 featured -->
      <div class="project-card featured reveal">
        <div class="project-thumb" style="background:linear-gradient(135deg,#1a1a2e,#16213e,#0f3460)">
          <div style="width:72%;height:78%;background:rgba(255,255,255,.04);border-radius:10px;border:1px solid rgba(255,255,255,.12);overflow:hidden;display:flex;flex-direction:column">
            <div style="height:26px;background:#0d1117;display:flex;align-items:center;gap:.35rem;padding:0 .6rem"><div style="width:7px;height:7px;border-radius:50%;background:#ff5f56"></div><div style="width:7px;height:7px;border-radius:50%;background:#ffbd2e"></div><div style="width:7px;height:7px;border-radius:50%;background:#27c93f"></div></div>
            <div style="flex:1;background:#0d1117;padding:.6rem;display:grid;grid-template-columns:1fr 1fr 1fr;gap:.35rem;align-content:start">
              <div style="height:46px;background:linear-gradient(135deg,rgba(91,79,207,.22),rgba(91,79,207,.44));border:1px solid rgba(91,79,207,.55);border-radius:6px"></div>
              <div style="height:46px;background:linear-gradient(135deg,rgba(200,87,42,.22),rgba(200,87,42,.44));border:1px solid rgba(200,87,42,.55);border-radius:6px"></div>
              <div style="height:46px;background:linear-gradient(135deg,rgba(45,106,79,.22),rgba(45,106,79,.44));border:1px solid rgba(45,106,79,.55);border-radius:6px"></div>
              <div style="grid-column:span 3;height:52px;background:#161b22;border-radius:6px"></div>
            </div>
          </div>
          <div style="position:absolute;right:3%;bottom:3%;width:76px;border-radius:13px;border:1.5px solid rgba(255,255,255,.2);background:#1a1a2e;overflow:hidden;box-shadow:0 8px 24px rgba(0,0,0,.4)">
            <div style="height:14px;background:#111;display:flex;align-items:center;justify-content:center"><div style="width:26px;height:4px;background:#222;border-radius:99px"></div></div>
            <div style="padding:.45rem"><div style="height:27px;background:linear-gradient(135deg,#5b4fcf,#8b5cf6);border-radius:5px"></div><div style="margin-top:.35rem;display:flex;gap:.25rem"><div style="flex:1;height:14px;background:#161b22;border-radius:3px"></div><div style="flex:1;height:14px;background:#161b22;border-radius:3px"></div></div></div>
          </div>
        </div>
        <div class="project-body">
          <div class="project-platform-tags"><span class="ptag ptag-web">React</span><span class="ptag ptag-flutter">Flutter</span><span class="ptag ptag-ios">Swift</span></div>
          <h3 class="project-title">Atlas — Design System & App Suite</h3>
          <p class="project-desc">Sistema de diseño compartido entre web, iOS y Android. Un token base en Figma que compila a Tailwind, Flutter ThemeData y SwiftUI. Tres plataformas, una fuente de verdad.</p>
          <div class="project-metrics">
            <div class="pm-item"><div class="pm-val">138k</div><div class="pm-label">Descargas</div></div>
            <div class="pm-item"><div class="pm-val">4.9★</div><div class="pm-label">App Store</div></div>
            <div class="pm-item"><div class="pm-val">−60%</div><div class="pm-label">QA visual</div></div>
            <div class="pm-item"><div class="pm-val">2.1s</div><div class="pm-label">Load time</div></div>
          </div>
          <div class="project-footer"><span class="project-tech">React · Flutter · Swift · Style Dictionary · Storybook</span><a href="#" class="project-link">Ver <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a></div>
        </div>
      </div>
      <!-- 2 -->
      <div class="project-card reveal">
        <div class="project-thumb" style="background:linear-gradient(135deg,#0d2818,#1a5435)">
          <div style="width:62%;height:74%;border-radius:18px;border:1.5px solid rgba(255,255,255,.15);overflow:hidden;display:flex;flex-direction:column">
            <div style="height:18px;background:#0a1f13;display:flex;align-items:center;justify-content:center"><div style="width:36px;height:4px;background:#1a3a22;border-radius:99px"></div></div>
            <div style="padding:.55rem;background:#0a1f13;flex:1">
              <div style="background:linear-gradient(135deg,#2d6a4f,#52b788);border-radius:7px;padding:.55rem;color:white;font-size:9px;font-family:monospace"><div style="opacity:.6;font-size:8px">PASOS HOY</div><div style="font-size:15px;font-weight:700">8,432</div></div>
              <div style="margin-top:.35rem;display:grid;grid-template-columns:1fr 1fr;gap:.25rem"><div style="background:#112218;border-radius:5px;height:24px"></div><div style="background:#112218;border-radius:5px;height:24px"></div></div>
            </div>
          </div>
        </div>
        <div class="project-body">
          <div class="project-platform-tags"><span class="ptag ptag-flutter">Flutter</span><span class="ptag ptag-ios">SwiftUI</span></div>
          <h3 class="project-title">FitTrack — Health App</h3>
          <p class="project-desc">App de salud con versiones nativas iOS (SwiftUI) y Android (Flutter). UI idéntica, rendimiento nativo, HealthKit integrado.</p>
          <div class="project-metrics">
            <div class="pm-item"><div class="pm-val">52k</div><div class="pm-label">Usuarios</div></div>
            <div class="pm-item"><div class="pm-val">42%</div><div class="pm-label">Ret. 60 días</div></div>
          </div>
          <div class="project-footer"><span class="project-tech">Flutter · Dart · SwiftUI · HealthKit</span><a href="#" class="project-link">Ver <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a></div>
        </div>
      </div>
      <!-- 3 -->
      <div class="project-card reveal">
        <div class="project-thumb" style="background:linear-gradient(135deg,#1a0a2e,#3d1a78)">
          <div style="width:78%;height:78%;display:flex;flex-direction:column;gap:.35rem">
            <div style="display:flex;gap:.35rem;height:40%"><div style="flex:2;background:rgba(255,255,255,.08);border-radius:7px;border:1px solid rgba(255,255,255,.12);display:flex;align-items:center;justify-content:center"><div style="font-size:16px;color:rgba(255,255,255,.3)">≡</div></div><div style="flex:3;background:rgba(255,255,255,.05);border-radius:7px;border:1px solid rgba(255,255,255,.08)"></div></div>
